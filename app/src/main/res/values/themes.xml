<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AndroidProjektAudioPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:colorBackground">@color/black</item>
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="searchViewStyle">@style/CustomSearchView</item>
    </style>

    <style name="CustomSearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:textColorHint">@color/subtext</item>
        <item name="iconifiedByDefault">false</item>
    </style>

    <style name="Theme.AndroidProjektAudioPlayer" parent="Base.Theme.AndroidProjektAudioPlayer" />
</resources>
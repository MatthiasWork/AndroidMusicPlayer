<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detailsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="24dp">

    <!-- Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:icon="@drawable/arrow_back_24px"
        app:iconTint="@color/primary_accent"
        app:iconSize="26dp"
        android:backgroundTint="@android:color/transparent"
        app:strokeWidth="0dp"
        style="@style/Widget.Material3.Button.IconButton"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Platzhalter Cover Art -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCoverArt"
        android:layout_width="250dp"
        android:layout_height="250dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/primary_accent"
        app:strokeWidth="2dp"
        app:cardBackgroundColor="@color/detailBackground"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardTitle"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/ivCoverArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/library_music_40px"
            android:scaleType="fitCenter"
            android:padding="40dp"
            app:tint="@color/primary_accent"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Titel Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="32dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/detailBackground"
        app:layout_constraintTop_toBottomOf="@id/cardCoverArt"
        app:layout_constraintBottom_toTopOf="@id/cardArtist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Titel"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_accent"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:padding="10dp"/>
    </androidx.cardview.widget.CardView>

    <!-- Künstler Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/detailBackground"
        app:layout_constraintTop_toBottomOf="@id/cardTitle"
        app:layout_constraintBottom_toTopOf="@id/cardDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDetailArtist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Künstler"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:padding="12dp"/>
    </androidx.cardview.widget.CardView>

    <!-- Datum Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="8dp"
        android:layout_marginHorizontal="32dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/detailBackground"
        app:layout_constraintTop_toBottomOf="@id/cardArtist"
        app:layout_constraintBottom_toTopOf="@id/llDetailPlayback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Datum"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:padding="10dp"/>
    </androidx.cardview.widget.CardView>

    <!-- Playback Buttons (zentriert) -->
    <LinearLayout
        android:id="@+id/llDetailPlayback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/cardDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailPrevious"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/skip_previous_24px"
            app:iconTint="@color/primary_accent"
            app:iconSize="36dp"
            style="@style/Widget.Material3.Button.IconButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/pause_24px"
            app:iconTint="@color/primary_accent"
            app:iconSize="36dp"
            android:layout_marginHorizontal="16dp"
            style="@style/Widget.Material3.Button.IconButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/skip_next_24px"
            app:iconTint="@color/primary_accent"
            app:iconSize="36dp"
            style="@style/Widget.Material3.Button.IconButton"/>

    </LinearLayout>

    <!-- Volume Button (rechts ausgerichtet) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDetailVolume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:icon="@drawable/brand_awareness_24px"
        app:iconTint="@color/primary_accent"
        app:iconSize="36dp"
        style="@style/Widget.Material3.Button.IconButton"
        app:layout_constraintTop_toTopOf="@id/llDetailPlayback"
        app:layout_constraintBottom_toBottomOf="@id/llDetailPlayback"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Zeit kombiniert -->
    <TextView
        android:id="@+id/tvTimeCombined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00 / 0:00"
        android:textSize="14sp"
        android:textColor="@color/subtext"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/llDetailPlayback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/sbDetailProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTimeCombined"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
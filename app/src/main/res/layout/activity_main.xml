<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="15dp"
    android:id="@+id/main">

    <!-- Oberer Bereich -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Linke kleine RecyclerView -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlaylists"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddPlaylist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center"
                android:layout_margin="6dp"
                app:srcCompat="@drawable/add_box_24px"
                app:fabSize="normal"
                app:maxImageSize="30sp"/>

        </FrameLayout>

        <!-- Orange Abstandhalter -->
        <View
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <!-- Rechter Hauptbereich -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:orientation="vertical">

            <!-- Kopfzeile (Grün + Blau) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Grüne TextView -->
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="SUCHE HIER"
                    android:padding="8dp"
                    android:id="@+id/etSearch" />

                <!-- Blauer Button -->
                <com.google.android.material.button.MaterialButton
                    android:layout_width="wrap_content"
                    android:layout_height="45sp"
                    app:icon="@drawable/unknown_med_24px"
                    android:padding="8dp"
                    app:iconSize="30sp"
                    android:id="@+id/btnChangeSortOrder"/>
            </LinearLayout>

            <!-- Hellrotes LinearLayout -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleSortOptions"
                android:layout_width="match_parent"
                android:layout_height="38sp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSortByName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:icon="@drawable/match_case_24px"
                    app:iconSize="30sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSortByArtist"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:icon="@drawable/person_24px"
                    app:iconSize="30sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSortByGenre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:icon="@drawable/genres_24px"
                    app:iconSize="30sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSortByRelease"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:icon="@drawable/calendar_month_24px"
                    app:iconSize="30sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Große RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAudioTracks"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>
    </LinearLayout>

    <!-- Unterer roter Bereich -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.3"
        android:orientation="vertical">

        <!-- Große klickbare Fläche für Detailansicht -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOpenDetail"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/sbProgress"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/info_24px"
                android:scaleType="centerInside"
                android:padding="20dp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Titel -->
        <TextView
            android:id="@+id/tvTitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Titel"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="@id/cardOpenDetail"
            app:layout_constraintStart_toEndOf="@id/cardOpenDetail"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Untertitel -->
        <TextView
            android:id="@+id/tvSubTitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Untertitel"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"

            app:layout_constraintTop_toBottomOf="@id/tvTitleText"
            app:layout_constraintStart_toEndOf="@id/cardOpenDetail"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Mittlere Buttons -->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvSubTitleText"
            app:layout_constraintBottom_toTopOf="@id/sbProgress"
            app:layout_constraintStart_toEndOf="@id/cardOpenDetail"
            app:layout_constraintEnd_toStartOf="@id/btnVolume">

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/skip_previous_24px"
                app:iconSize="30dp"
                android:id="@+id/btnPrevious"
                style="@style/Widget.Material3.Button.IconButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/pause_24px"
                app:iconSize="30dp"
                android:id="@+id/btnPause"
                style="@style/Widget.Material3.Button.IconButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/skip_next_24px"
                app:iconSize="30dp"
                android:id="@+id/btnNext"
                style="@style/Widget.Material3.Button.IconButton"/>
        </LinearLayout>

        <!-- Lautsprecher-Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/buttonContainer"
            app:layout_constraintBottom_toBottomOf="@id/buttonContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:icon="@drawable/brand_awareness_24px"
            app:iconSize="30dp"
            style="@style/Widget.Material3.Button.IconButton"/>

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/sbProgress"
            android:layout_width="0dp"
            android:layout_height="25sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
